# ========== Frontend (Vite) ==========
# Backend yoqilgan bo‘lsa true qiling; `npm run dev` Vite proxy orqali /api chaqiradi
VITE_USE_BACKEND=true
# Bo‘sh = shu domen + /api (proxy). Alohida API domen bo‘lsa: https://api.sizning-domen.uz
VITE_API_BASE=

# Eski dev rejim: faqat VITE_USE_BACKEND=false bo‘lsa ishlatiladi (tavsiya etilmaydi)
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=
VITE_TELEGRAM_GROUP_LINK=https://t.me/

# Alohida to‘liq URL bo‘lsa shu ishlatiladi (masalan production API)
VITE_ORDER_API_URL=

# ========== Server (ildizdagi .env — `node server/index.js` / concurrently) ==========
# server/.env.example dagi TELEGRAM_*, SESSION_SECRET, ADMIN_* ni shu yerga ham qo‘shing
# yoki server papkasida alohida .env (dotenv loyiha ildizidan o‘qiydi)
